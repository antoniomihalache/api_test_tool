# Environment Configuration
# Copy this file to .env and fill in your values

# ── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MongoDB ────────────────────────────────────────────────────
# Default for Docker Compose Mongo service. If you use a local/external Mongo,
# set this to e.g. mongodb://localhost:27017/perf_platform.
MONGODB_URI=mongodb://mongo:27017/perf_platform

# ── JWT (change in production) ─────────────────────────────────
JWT_SECRET=change_me_in_production_use_32+_chars
JWT_EXPIRES_IN=24h

# ── Execution Runner ───────────────────────────────────────────
# Options: docker | kubernetes
RUNNER_MODE=docker

# Docker socket for spawning k6 containers
DOCKER_SOCKET=/var/run/docker.sock

# k6 Docker image
K6_IMAGE=grafana/k6:0.54.0

# Shared volume for k6 scripts (must be accessible by spawned containers)
K6_SCRIPTS_PATH=/tmp/k6-scripts

# ── Kubernetes Runner (future) ─────────────────────────────────
KUBECONFIG=/root/.kube/config
K8S_NAMESPACE=perf-tests
K6_K8S_IMAGE=grafana/k6:0.54.0

# ── Prometheus / Grafana ───────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090

# k6 remote write endpoint
K6_PROMETHEUS_RW_SERVER_URL=http://prometheus:9090/api/v1/write

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── File Storage ───────────────────────────────────────────────
REPORTS_PATH=/app/reports

# ── Bootstrap Default User (optional) ──────────────────────────
# Used by backend/scripts/seed-user-only.js when running npm run bootstrap.
DEFAULT_ADMIN_EMAIL=admin@perf-platform.local
DEFAULT_ADMIN_PASSWORD=Admin1234!
